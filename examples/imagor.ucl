jail "hypha-imagor" {
  setup {
    imagor {
      type = "ansible"; 
      url = "https://github.com/hyphatech/jailrun-hub/blob/main/playbooks/imagor/latest/playbook.yml";
    }
  }
  forward {
    pg { host = 9000; jail = 8000; }
  }
  exec {
    imagor {
      cmd = "imagor";
      env {
        IMAGOR_UNSAFE = "1";
      }
    }
  }
}
